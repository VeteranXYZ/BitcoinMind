{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bitcoinmind",
  "main": "./worker/index.js",
  "compatibility_date": "2026-04-24",
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "bitcoinmind.com",
      "custom_domain": true
    },
    {
      "pattern": "www.bitcoinmind.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
