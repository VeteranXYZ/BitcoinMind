---
import Base from '@/layouts/Base.astro';
---
<Base
  title="Not Found"
  description="The page you were looking for is not on BitcoinMind."
  path="/404"
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">404</div>
        <h1 class="ph-title">Not <em>here.</em></h1>
        <p class="ph-desc">The page you were looking for is not on this site. Try the <a href="/" style="color: var(--gold-hi); text-decoration: underline;">home page</a> or jump to the <a href="/books" style="color: var(--gold-hi); text-decoration: underline;">library</a>.</p>
      </div>
    </div>
  </div>
</Base>
