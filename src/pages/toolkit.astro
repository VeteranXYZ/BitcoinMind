---
import Base from '@/layouts/Base.astro';
import ToolFilter from '@/components/ToolFilter';
import { TOOLS } from '@/data/tools';

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'BitcoinMind Toolkit',
  itemListElement: TOOLS.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'SoftwareApplication',
      name: t.name,
      applicationCategory: t.cat,
      description: t.desc,
      url: t.link,
    },
  })),
};
---
<Base
  title="The Toolkit"
  description="Tools for holding, verifying, and reading Bitcoin without guessing."
  path="/toolkit"
  jsonLd={itemList}
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">Toolkit</div>
        <h1 class="ph-title">The <em>Toolkit</em></h1>
        <p class="ph-desc">Tools for holding, verifying, and reading Bitcoin without guessing. Ownership first, intelligence second.</p>
      </div>
      <ToolFilter client:visible />
    </div>
  </div>
</Base>
