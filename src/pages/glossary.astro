---
import Base from '@/layouts/Base.astro';
import { GLOSSARY } from '@/data/glossary';

const categories = [
  { key: 'monetary', label: 'Monetary' },
  { key: 'technical', label: 'Technical' },
  { key: 'philosophical', label: 'Philosophical' },
] as const;
---
<Base
  title="Glossary"
  description="Concepts as anchors, not dictionary entries."
  path="/glossary"
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">Concepts</div>
        <h1 class="ph-title">The <em>Glossary</em></h1>
        <p class="ph-desc">Concepts as anchors, not dictionary entries. Each term is a way into the idea.</p>
      </div>

      {categories.map((cat) => {
        const entries = GLOSSARY.filter((g) => g.category === cat.key);
        return (
          <div class="gl-section">
            <div class="gl-cat-hd">
              <span class="gl-cat-label">{cat.label}</span>
              <span class="gl-cat-count">{entries.length}</span>
            </div>

            <div class="gl-list">
              {entries.map((entry) => (
                <div class="gl-entry" id={entry.id}>
                  <div class="gl-term-row">
                    <h2 class="gl-term">{entry.term}</h2>
                  </div>
                  <p class="gl-body">{entry.body}</p>
                  {entry.links && (
                    <div class="gl-links">
                      {entry.links.map((l) => (
                        <a class="gl-link" href={l.href}>{l.label} →</a>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Base>

<style>
  .gl-section {
    margin-bottom: var(--sp-11);
  }

  .gl-cat-hd {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid var(--bdr);
    margin-bottom: var(--sp-7);
  }

  .gl-cat-label {
    font-family: var(--font-serif);
    font-size: var(--fz-3xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-snug);
    color: var(--tx);
  }

  .gl-cat-count {
    font-family: var(--font-mono);
    font-size: var(--fz-3xs);
    color: var(--tx-3);
    letter-spacing: var(--ls-5);
    border: 1px solid var(--bdr);
    padding: 3px var(--sp-2);
    border-radius: var(--radius-sm);
  }

  .gl-list {
    display: flex;
    flex-direction: column;
  }

  .gl-entry {
    padding: var(--sp-7) 0;
    border-bottom: 1px solid var(--bdr);
    max-width: 768px;
  }

  .gl-entry:last-child {
    border-bottom: none;
  }

  .gl-term-row {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }

  .gl-term {
    font-family: var(--font-serif);
    font-size: var(--fz-xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-snug);
    color: var(--tx);
  }

  .gl-body {
    font-family: var(--font-body);
    font-size: var(--fz-md);
    line-height: var(--lh-loose);
    color: var(--tx-2);
  }

  .gl-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin-top: var(--sp-3);
  }

  .gl-link {
    font-family: var(--font-mono);
    font-size: var(--fz-xs);
    color: var(--gold);
    letter-spacing: var(--ls-3);
    transition: color var(--ease-fast);
  }
  .gl-link:hover {
    color: var(--gold-hi);
  }

  @media (max-width: 640px) {
    .gl-section { margin-bottom: var(--sp-9); }
    .gl-entry { padding: var(--sp-6) 0; }
    .gl-cat-label { font-size: var(--fz-2xl); }
    .gl-cat-hd { margin-bottom: var(--sp-6); }
    .gl-term-row { flex-direction: column; align-items: flex-start; gap: var(--sp-1); }
  }
</style>
