---
import Base from '@/layouts/Base.astro';
import Tag from '@/components/Tag.astro';
import { TIMELINE } from '@/data/timeline';
---
<Base
  title="Timeline"
  description="Seventeen years of Bitcoin signal, stripped of market noise. Ideas, events, and protocol moments from the whitepaper to the present block."
  path="/timeline"
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">Timeline</div>
        <h1 class="ph-title">The <em>Timeline</em></h1>
        <p class="ph-desc">Seventeen years of signal, stripped of market noise. Ideas, events, and protocol moments only.</p>
      </div>

      <div class="tl-wrap">
        {TIMELINE.map((ev, i) => (
          <div class:list={['tl-node', ev.hiei && 'tl-node--hiei']} id={ev.id}>
            <div class="tl-date">
              <span class="tl-year">{ev.year}</span>
              {ev.month && <span class="tl-month">{ev.month}</span>}
            </div>
            <div class="tl-rail">
              <div class="tl-dot" />
              {i < TIMELINE.length - 1 && <div class="tl-line" />}
            </div>
            <div class="tl-content">
              {ev.hiei && <div class="tl-personal">Personal Record</div>}
              <h2 class="tl-title">{ev.title}</h2>
              <p class="tl-body">{ev.body}</p>
              {ev.hiei && (
                <div class="tl-hiei">
                  <span class="tl-hiei-lbl">Hiei</span>
                  <p>{ev.hiei}</p>
                </div>
              )}
              {ev.tags && (
                <div class="tl-tags">
                  {ev.tags.map((t) => <Tag label={t} />)}
                </div>
              )}
              {ev.links && (
                <div class="tl-links">
                  {ev.links.map((l) => (
                    <a class="tl-link" href={l.href}>{l.label} →</a>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Base>

<style>
  .tl-wrap {
    max-width: 1100px;
  }

  .tl-node {
    display: grid;
    grid-template-columns: 160px 48px minmax(0, 1fr);
    gap: var(--sp-5);
    min-height: 0;
  }

  .tl-date {
    grid-column: 1;
    display: flex;
    justify-content: flex-end;
    align-items: baseline;
    gap: var(--sp-2);
    padding-top: 2px;
    text-align: right;
  }

  .tl-rail {
    grid-column: 2;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    /* Optical alignment with the first line of .tl-title */
    padding-top: 6px;
  }

  .tl-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 0 3px var(--gold-dim);
    flex-shrink: 0;
    z-index: 1;
  }

  .tl-line {
    width: 1px;
    flex: 1;
    background: var(--bdr);
    margin-top: var(--sp-1);
  }

  .tl-content {
    grid-column: 3;
    padding: var(--sp-5);
    margin-bottom: var(--sp-7);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    background: var(--surf);
  }

  /* Last node: its .tl-content bottom margin is zeroed so the gap to
     the footer comes solely from .page's padding-bottom. */
  .tl-node:last-child .tl-content {
    margin-bottom: 0;
  }

  .tl-node--hiei .tl-dot {
    width: 12px;
    height: 12px;
    background: var(--gold-hi);
    box-shadow: 0 0 0 4px var(--gold-dim);
  }

  .tl-year {
    font-family: var(--font-mono);
    font-size: var(--fz-sm);
    font-weight: var(--fw-medium);
    color: var(--gold-hi);
    letter-spacing: var(--ls-7);
  }

  .tl-month {
    font-family: var(--font-mono);
    font-size: var(--fz-3xs);
    color: var(--tx-3);
    letter-spacing: var(--ls-5);
    text-transform: uppercase;
  }

  .tl-personal {
    display: inline-flex;
    margin-bottom: var(--sp-3);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-sm);
    padding: 3px var(--sp-2);
    font-family: var(--font-body);
    font-size: var(--fz-3xs);
    font-weight: var(--fw-semi);
    color: var(--gold-hi);
    letter-spacing: var(--ls-7);
    text-transform: uppercase;
  }

  .tl-title {
    font-family: var(--font-body);
    font-size: var(--fz-xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-snug);
    line-height: var(--lh-snug);
    margin-bottom: var(--sp-3);
    color: var(--tx);
  }

  .tl-body {
    font-family: var(--font-body);
    font-size: var(--fz-prose);
    line-height: var(--lh-loose);
    color: var(--tx-2);
    margin-bottom: var(--sp-3);
  }

  .tl-hiei {
    background: var(--surf);
    border-left: 3px solid var(--gold);
    padding: var(--sp-3) var(--sp-4);
    margin: var(--sp-3) 0;
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .tl-hiei-lbl {
    font-family: var(--font-body);
    font-size: var(--fz-3xs);
    font-weight: var(--fw-semi);
    color: var(--gold-hi);
    letter-spacing: var(--ls-9);
    text-transform: uppercase;
    display: block;
    margin-bottom: var(--sp-2);
  }

  .tl-hiei p {
    font-family: var(--font-body);
    font-size: var(--fz-prose);
    font-style: italic;
    line-height: var(--lh-relaxed);
    color: var(--tx-2);
  }

  .tl-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: var(--sp-3);
  }

  .tl-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin-top: var(--sp-3);
  }

  .tl-link {
    font-family: var(--font-body);
    font-size: var(--fz-xs);
    font-weight: var(--fw-semi);
    color: var(--gold-hi);
    letter-spacing: var(--ls-3);
    transition: color var(--ease-fast);
  }
  .tl-link:hover {
    color: var(--gold-hi);
  }

  @media (max-width: 640px) {
    .tl-node {
      grid-template-columns: 24px 1fr;
      gap: var(--sp-3);
    }
    .tl-date {
      grid-column: 2;
      justify-content: flex-start;
      padding-top: 0;
      margin-bottom: var(--sp-2);
      grid-row: 1;
    }
    .tl-wrap {
      max-width: 760px;
    }
    .tl-rail {
      grid-column: 1;
      grid-row: 1 / span 2;
    }
    .tl-content {
      grid-column: 2;
      grid-row: 2;
      padding: var(--sp-5);
      margin-bottom: var(--sp-5);
    }
  }
</style>
