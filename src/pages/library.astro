---
import Base from '@/layouts/Base.astro';
import LibraryCard from '@/components/LibraryCard.astro';
import StudyLoop from '@/components/StudyLoop.astro';
import StudyNext from '@/components/StudyNext.astro';
import { LIBRARY } from '@/data/library';

const TAGS = ['All', 'Money', 'Economics', 'Foundations', 'Technical', 'Protocol', 'History', 'Macro Companion', 'Sovereignty', 'Beginner', 'Intermediate', 'Advanced'];
const LAYER_DESC: Record<number, string> = {
  1: 'Accessible entrances to money and open monetary networks.',
  2: 'History, protocol mechanics, settlement, and governance.',
  3: 'Human consequences, institutions, and claims about sovereignty.',
};
const CURATED_ORDER = [
  'the-internet-of-money', 'broken-money', 'the-bitcoin-standard',
  'digital-gold', 'inventing-bitcoin', 'grokking-bitcoin', 'mastering-bitcoin',
  'layered-money', 'the-blocksize-war', 'the-price-of-tomorrow',
  'check-your-financial-privilege', '21-lessons', 'the-sovereign-individual',
];
const orderIndex = new Map(CURATED_ORDER.map((id, index) => [id, index]));
const ORDERED_LIBRARY = [...LIBRARY].sort((a, b) =>
  (orderIndex.get(a.id) ?? Number.MAX_SAFE_INTEGER) - (orderIndex.get(b.id) ?? Number.MAX_SAFE_INTEGER));
const filterValues = (values: string[]) => values.map((value) => value.toLowerCase()).join('|');
const libraryValues = (item: typeof LIBRARY[number]) => filterValues([
  ...item.tags,
  item.difficulty,
  item.group,
  item.pathStage,
  item.layerLabel.replace(/^Layer \d+ - /, ''),
]);
const librarySearch = (item: typeof LIBRARY[number]) => [
  item.title,
  item.author,
  item.learningRole,
  item.shortDescription,
  ...item.tags,
].join(' ').toLowerCase();

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'BitcoinMind Library',
  itemListElement: ORDERED_LIBRARY.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'CreativeWork',
      name: item.title,
      author: { '@type': 'Person', name: item.author },
      description: item.shortDescription,
      url: item.link,
    },
  })),
};
---
<Base
  title="Bitcoin Library"
  metaTitle="Bitcoin Books — Money, Protocol, Custody, and History"
  description="A selective Bitcoin book list ordered from money and history through protocol mechanics, governance, self-custody, human rights, and institutional change."
  ogTitle="The Bitcoin Library — BitcoinMind"
  ogDescription="A short shelf ordered by learning role: orientation, mechanism, governance, and consequences."
  twitterTitle="The Bitcoin Library — BitcoinMind"
  twitterDescription="A short shelf ordered by learning role: orientation, mechanism, governance, and consequences."
  path="/library"
  jsonLd={itemList}
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">Library</div>
        <h1 class="ph-title">The Bitcoin <em>Library</em></h1>
        <p class="ph-desc">A short shelf ordered by learning role: orientation, mechanism, governance, and consequences. Inclusion is not agreement.</p>
      </div>
      <StudyLoop compact />
      <div data-filter-scope data-active-filter="all">
        <div class="fb" role="group" aria-label="Filter library">
          <span class="fb-lbl">Filter:</span>
          <input
            class="srch"
            type="search"
            aria-label="Search library"
            placeholder="Search..."
            data-filter-search
            oninput="window.BitcoinMindFilterInput && window.BitcoinMindFilterInput(this)"
          />
          {TAGS.map((t) => (
            <button
              type="button"
              class={`fb-btn ${t === 'All' ? 'on' : ''}`}
              aria-pressed={t === 'All' ? 'true' : 'false'}
              data-filter-button
              data-filter={t.toLowerCase()}
              onclick="window.BitcoinMindFilterClick && window.BitcoinMindFilterClick(this)"
            >{t}</button>
          ))}
        </div>

        {[1, 2, 3].map((layer) => {
          const layerItems = ORDERED_LIBRARY.filter((item) => item.layer === layer);
          return (
            <div class="layer" data-filter-group>
              <div class="layer-hd">
                <span class="layer-n">Layer {layer}</span>
                <span class="layer-name">{layerItems[0]?.layerLabel.replace(/^Layer \d+ - /, '')}</span>
              </div>
              <p class="layer-desc">{LAYER_DESC[layer]}</p>
              <div class="grid-auto">
                {layerItems.map((item) => (
                  <div data-filter-card data-filter-values={libraryValues(item)} data-filter-search={librarySearch(item)}>
                    <LibraryCard item={item} />
                  </div>
                ))}
              </div>
            </div>
          );
        })}

        <p class="no-res" data-filter-empty hidden>No library items match this filter.</p>
      </div>
      <StudyNext
        previous={{ href: '/primer', label: 'Primer', description: 'Return to the five-step entrance.' }}
        next={{ href: '/texts', label: 'Foundational Texts', description: 'Move from curated interpretation to primary and foundational writing.' }}
      />
    </div>
  </div>
</Base>
