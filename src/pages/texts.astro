---
import Base from '@/layouts/Base.astro';
import TextFilter from '@/components/TextFilter';
import { TEXTS } from '@/data/texts';

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'BitcoinMind Primary Texts',
  itemListElement: TEXTS.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Article',
      headline: item.title,
      author: { '@type': 'Person', name: item.author },
      datePublished: String(item.year),
      description: item.shortDescription,
      url: item.link,
    },
  })),
};
---
<Base
  title="Bitcoin Primary Texts"
  description="Essential Bitcoin texts including the whitepaper, monetary writings, adoption frameworks, objections, and philosophical work on time and sovereignty."
  path="/texts"
  jsonLd={itemList}
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">Primary Texts</div>
        <h1 class="ph-title">Primary <em>Texts</em></h1>
        <p class="ph-desc">Texts — primary writings that shaped Bitcoin thinking. The whitepaper first, then the arguments around it.</p>
      </div>
      <TextFilter client:visible />
    </div>
  </div>
</Base>
