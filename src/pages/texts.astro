---
import Base from '@/layouts/Base.astro';
import EssayFilter from '@/components/EssayFilter';
import { ESSAYS } from '@/data/essays';

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'BitcoinMind Primary Texts',
  itemListElement: ESSAYS.map((e, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Article',
      headline: e.title,
      author: { '@type': 'Person', name: e.author },
      datePublished: String(e.year),
      description: e.desc,
      url: e.link,
    },
  })),
};
---
<Base
  title="Texts"
  description="The papers and essays that carry the idea, not the commentary around it."
  path="/texts"
  jsonLd={itemList}
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">Primary Texts</div>
        <h1 class="ph-title">Primary <em>Texts</em></h1>
        <p class="ph-desc">The whitepaper first, then the thinkers around it. No summaries standing in for the source.</p>
      </div>
      <EssayFilter client:visible />
    </div>
  </div>
</Base>
