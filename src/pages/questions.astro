---
import Base from '@/layouts/Base.astro';
import { QUESTIONS } from '@/data/questions';
import { SITE } from '@/lib/seo';

const questionsLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Bitcoin Questions, Tradeoffs, and Open Problems',
  itemListElement: QUESTIONS.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `${SITE.url}/questions#${item.id}`,
    name: item.question,
  })),
};
---
<Base
  title="Bitcoin Questions"
  metaTitle="Bitcoin Questions — Clear Answers, Tradeoffs, and Open Problems"
  description="Careful answers to difficult Bitcoin questions about energy, buying, the 21 million limit, miner fees, smart contracts, self-custody, and protocol change."
  path="/questions"
  jsonLd={questionsLd}
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">Questions</div>
        <h1 class="ph-title">Open <em>Questions</em></h1>
        <p class="ph-desc">Answers that distinguish protocol facts from forecasts, values, and unresolved tradeoffs.</p>
      </div>

      <div class="qa-list">
        {QUESTIONS.map((q, i) => (
          <div class="qa-item" id={q.id}>
            <div class="qa-q-row">
              <span class="qa-num">Q{String(i + 1).padStart(2, '0')}</span>
              <h2 class="qa-question">{q.question}</h2>
            </div>
            <div class="qa-answer-wrap">
              <div class="qa-meta">
                <span class="qa-date">{q.date}</span>
                <span class="qa-by">Hiei</span>
              </div>
              <div class="qa-answer">
                <p>{q.answer}</p>
              </div>
              {q.links && (
                <div class="qa-links">
                  {q.links.map((l) => (
                    <a class="qa-link" href={l.href}>{l.label} →</a>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>

      <div class="qa-submit">
        <div class="qa-submit-hd">
          <div class="a-eye">Submit</div>
          <h2 class="qa-submit-title">Have a question?</h2>
        </div>
        <p class="qa-submit-body">Send a question that survives a quick search and deserves a careful answer. The most useful questions expose an assumption, a tradeoff, or evidence that could change the conclusion.</p>
        <a class="qa-submit-cta" href={`mailto:${SITE.contactEmail}?subject=Question for BitcoinMind`} target="_blank" rel="noopener noreferrer">
          <span class="qa-submit-arrow">→</span>
          <span>{SITE.contactEmail}</span>
        </a>
      </div>
    </div>
  </div>
</Base>

<style>
  .qa-list {
    width: 100%;
  }

  .qa-item {
    margin-bottom: var(--sp-11);
    padding-bottom: var(--sp-11);
    border-bottom: 1px solid var(--bdr);
  }
  .qa-item:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .qa-q-row {
    display: grid;
    grid-template-columns: 64px minmax(0, 820px);
    align-items: flex-start;
    gap: var(--sp-4);
    margin-bottom: var(--sp-5);
  }

  .qa-num {
    font-family: var(--font-mono);
    font-size: var(--fz-3xs);
    color: var(--gold);
    letter-spacing: var(--ls-5);
    border: 1px solid var(--border-accent);
    padding: 3px var(--sp-2);
    border-radius: var(--radius-sm);
    justify-self: start;
    /* Optical alignment with first line of question text */
    margin-top: var(--sp-1);
  }

  .qa-question {
    font-family: var(--font-body);
    font-size: var(--fz-xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-snug);
    line-height: var(--lh-snug);
    color: var(--tx);
    max-width: 820px;
  }

  .qa-answer-wrap {
    /* Align with question text: qa-num width + gap */
    padding-left: calc(64px + var(--sp-4));
    max-width: calc(820px + 64px + var(--sp-4));
  }

  .qa-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }

  .qa-date {
    font-family: var(--font-mono);
    font-size: var(--fz-3xs);
    color: var(--tx-3);
    letter-spacing: var(--ls-7);
    text-transform: uppercase;
  }

  .qa-by {
    font-family: var(--font-body);
    font-size: var(--fz-3xs);
    color: var(--gold);
    letter-spacing: var(--ls-7);
    text-transform: uppercase;
  }

  .qa-answer {
    font-family: var(--font-body);
    font-size: var(--fz-md);
    line-height: var(--lh-loose);
    color: var(--tx-2);
  }

  .qa-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin-top: var(--sp-3);
  }

  .qa-link {
    font-family: var(--font-body);
    font-size: var(--fz-xs);
    color: var(--gold);
    letter-spacing: var(--ls-3);
    transition: color var(--ease-fast);
  }
  .qa-link:hover {
    color: var(--gold-hi);
  }

  /* Submit section */
  .qa-submit {
    width: 100%;
    margin-top: var(--sp-9);
    padding: var(--sp-7) var(--sp-7);
    background: var(--surf);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    column-gap: var(--sp-8);
    align-items: start;
  }

  .qa-submit-hd {
    margin-bottom: 0;
  }

  .qa-submit-title {
    font-family: var(--font-body);
    font-size: var(--fz-2xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-snug);
  }

  .qa-submit-body {
    font-family: var(--font-body);
    font-size: var(--fz-md);
    line-height: var(--lh-relaxed);
    color: var(--tx-2);
    margin-bottom: var(--sp-5);
    max-width: 700px;
  }

  .qa-submit-cta {
    grid-column: 2;
    justify-self: start;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    font-family: var(--font-body);
    font-size: var(--fz-sm);
    color: var(--tx);
    padding: var(--sp-3) var(--sp-4);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    max-width: 100%;
    transition: border-color var(--ease-fast), background var(--ease-fast);
  }
  .qa-submit-cta:hover {
    border-color: var(--border-accent);
    background: var(--surf-2);
  }

  .qa-submit-arrow {
    color: var(--gold);
    font-size: var(--fz-xs);
  }

  .qa-submit-cta span:last-child {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  @media (max-width: 900px) {
    .qa-submit {
      grid-template-columns: 1fr;
      row-gap: var(--sp-3);
    }
    .qa-submit-cta {
      grid-column: auto;
    }
  }

  @media (max-width: 640px) {
    .qa-q-row {
      grid-template-columns: 1fr;
      gap: var(--sp-2);
    }
    .qa-answer-wrap {
      padding-left: 0;
      max-width: none;
      margin-top: var(--sp-2);
    }
    .qa-submit {
      padding: var(--sp-5) var(--sp-4);
    }
  }
</style>
