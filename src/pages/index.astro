---
import Base from '@/layouts/Base.astro';
import LibraryCard from '@/components/LibraryCard.astro';
import TextCard from '@/components/TextCard.astro';
import ToolkitCard from '@/components/ToolkitCard.astro';
import TodaysPick from '@/components/TodaysPick';
import PulsePlus from '@/components/PulsePlus';
import { LIBRARY } from '@/data/library';
import { TEXTS } from '@/data/texts';
import { TOOLKIT } from '@/data/toolkit';
import { SITE } from '@/lib/seo';

const foundationItems = LIBRARY.filter((item) => item.layer === 1);
const previewTexts = TEXTS.slice(0, 3);
const previewToolkit = TOOLKIT.slice(0, 3);
const textCount = TEXTS.length;

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.tagline,
  author: { '@type': 'Person', name: SITE.author },
};
---
<Base
  title={SITE.name}
  description={SITE.tagline}
  path="/"
  jsonLd={websiteLd}
>
  <div class="page">
    <div class="hero">
      <div class="c">
        <div class="hero-eye">bitcoinmind.com</div>
        <h1 class="hero-title">
          <span class="hero-t1">Bitcoin</span>
          <span class="hero-t2">Mind</span>
        </h1>
        <div class="hero-rule"><div class="hero-rule-dot"></div></div>
        <p class="hero-quote">A personal map for studying Bitcoin as money, protocol, and sovereignty.</p>
        <p class="hero-by">A public record by {SITE.author} · est. 2017</p>
        <TodaysPick client:only="preact" />
        <PulsePlus client:idle />
      </div>
    </div>

    <div class="c">
      <div class="section">
        <div class="sec-hd">
          <h2 class="sec-title">Begin with the <em>Primer</em></h2>
          <a class="va" href="/library">Open the Library →</a>
        </div>
        <div class="grid3">
          {foundationItems.map((item) => <LibraryCard item={item} preview />)}
        </div>
      </div>

      <div class="section">
        <div class="sec-hd">
          <h2 class="sec-title">Read the <em>Texts</em></h2>
          <a class="va" href="/texts">View all {textCount} texts →</a>
        </div>
        <div class="grid3">
          {previewTexts.map((item) => <TextCard item={item} preview />)}
        </div>
      </div>

      <div class="section">
        <div class="sec-hd">
          <h2 class="sec-title">Use the <em>Toolkit</em></h2>
          <a class="va" href="/toolkit">Open the Toolkit →</a>
        </div>
        <div class="grid3">
          {previewToolkit.map((item) => <ToolkitCard item={item} preview />)}
        </div>
      </div>

      <div class="section">
        <div class="sec-hd">
          <h2 class="sec-title">Go <em>Deeper</em></h2>
          <a class="va" href="/rabbit-holes">View all paths →</a>
        </div>
        <div class="grid3">
          <a class="card" href="/timeline">
            <div class="card-layer">Chronology</div>
            <div class="card-title">Timeline</div>
            <div class="card-desc card-desc--top">Seventeen years of signal. The ideas and events that shaped Bitcoin, from the whitepaper to the present block.</div>
            <div class="card-ft">
              <span class="card-meta">16 events</span>
              <span class="card-cta">EXPLORE →</span>
            </div>
          </a>
          <a class="card" href="/glossary">
            <div class="card-layer">Concepts</div>
            <div class="card-title">Glossary</div>
            <div class="card-desc card-desc--top">Not definitions — conceptual anchors. Each entry is a compact note on a core Bitcoin idea.</div>
            <div class="card-ft">
              <span class="card-meta">15 terms</span>
              <span class="card-cta">READ →</span>
            </div>
          </a>
          <a class="card" href="/debates">
            <div class="card-layer">Objections</div>
            <div class="card-title">Objections</div>
            <div class="card-desc card-desc--top">The strongest arguments against Bitcoin, answered without pretending they are weak.</div>
            <div class="card-ft">
              <span class="card-meta">6 objections</span>
              <span class="card-cta">READ →</span>
            </div>
          </a>
        </div>
      </div>

      <div class="section">
        <div class="sec-hd">
          <h2 class="sec-title">From <em>Hiei</em></h2>
        </div>
        <div class="hiei-links">
          <a class="hiei-link" href="/stack">
            <span class="hiei-link-title">Stack</span>
            <span class="hiei-link-desc">How I hold Bitcoin — not how much, but how and why.</span>
            <span class="hiei-link-cta">Read →</span>
          </a>
          <a class="hiei-link" href="/questions">
            <span class="hiei-link-title">Questions</span>
            <span class="hiei-link-desc">Reader questions, answered when I have something worth saying.</span>
            <span class="hiei-link-cta">Read →</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .hiei-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }

  .hiei-link {
    display: flex;
    flex-direction: column;
    padding: var(--sp-6) var(--sp-6);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    transition: border-color var(--ease-card), background var(--ease-card);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .hiei-link:hover {
    border-color: var(--gold);
    background: var(--surf);
  }

  .hiei-link-title {
    font-family: var(--font-serif);
    font-size: var(--fz-lg);
    font-weight: var(--fw-semi);
    letter-spacing: var(--ls-normal);
    margin-bottom: var(--sp-2);
  }

  .hiei-link-desc {
    font-family: var(--font-body);
    font-size: var(--fz-base);
    color: var(--tx-2);
    line-height: var(--lh-relaxed);
    flex: 1;
    margin-bottom: var(--sp-3);
  }

  .hiei-link-cta {
    font-family: var(--font-mono);
    font-size: var(--fz-3xs);
    color: var(--gold);
    letter-spacing: var(--ls-5);
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .hiei-links {
      grid-template-columns: 1fr;
    }
  }
</style>
