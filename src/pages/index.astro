---
import Base from '@/layouts/Base.astro';
import LibraryCard from '@/components/LibraryCard.astro';
import TextCard from '@/components/TextCard.astro';
import ToolkitCard from '@/components/ToolkitCard.astro';
import TodaysPick from '@/components/TodaysPick';
import PulsePlus from '@/components/PulsePlus';
import { LIBRARY } from '@/data/library';
import { TEXTS } from '@/data/texts';
import { TOOLKIT } from '@/data/toolkit';
import { TIMELINE } from '@/data/timeline';
import { GLOSSARY } from '@/data/glossary';
import { DEBATES } from '@/data/debates';
import { SITE } from '@/lib/seo';

const foundationItems = LIBRARY.filter((item) => item.layer === 1).slice(0, 2);
const previewTexts = TEXTS.slice(0, 2);
const previewToolkit = TOOLKIT.slice(0, 2);
const textCount = TEXTS.length;
const primaryDoors = [
  {
    title: 'Start',
    subtitle: 'The Source Primer',
    body: 'Five steps from the original paper to money, sovereignty, and a personal 2011 note.',
    ctas: [
      { href: '/primer', label: 'Primer', action: 'Begin' },
    ],
  },
  {
    title: 'Study',
    subtitle: 'Library + Texts',
    body: 'Books and writings arranged for monetary, technical, and sovereignty study.',
    meta: `${LIBRARY.length} library items · ${textCount} texts`,
    ctas: [
      { href: '/library', label: 'Library', meta: `${LIBRARY.length} items`, action: 'Browse' },
      { href: '/texts', label: 'Texts', meta: `${textCount} texts`, action: 'View' },
    ],
  },
  {
    title: 'Practice',
    subtitle: 'Toolkit + Paths',
    body: 'Tools and learning routes for observation, verification, custody, and deeper study.',
    meta: `${TOOLKIT.length} tools · 5 paths`,
    ctas: [
      { href: '/toolkit', label: 'Toolkit', meta: `${TOOLKIT.length} tools`, action: 'Use' },
      { href: '/paths', label: 'Paths', meta: '5 paths', action: 'Follow' },
    ],
  },
];

const deeperCards = [
  {
    href: '/timeline',
    title: 'Timeline',
    desc: 'Seventeen years of signal. The ideas and events that shaped Bitcoin, from the whitepaper to the present block.',
    meta: `${TIMELINE.length} events`,
    cta: 'EXPLORE →',
  },
  {
    href: '/glossary',
    title: 'Glossary',
    desc: 'Not definitions — conceptual anchors. Each entry is a compact note on a core Bitcoin idea.',
    meta: `${GLOSSARY.length} terms`,
    cta: 'READ →',
  },
  {
    href: '/objections',
    title: 'Objections',
    desc: 'The strongest arguments against Bitcoin, answered without pretending they are weak.',
    meta: `${DEBATES.length} objections`,
    cta: 'READ →',
  },
];

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.tagline,
  author: { '@type': 'Person', name: SITE.author },
};
---
<Base
  title={SITE.name}
  description={SITE.tagline}
  path="/"
  jsonLd={websiteLd}
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">bitcoinmind.com</div>
        <h1 class="ph-title">Bitcoin<em>Mind</em></h1>
        <p class="ph-desc">A personal map for studying Bitcoin as money, protocol, and sovereignty.</p>
        <p class="ph-meta">By Hiei · Since 2017</p>
      </div>

      <div class="home-divider"></div>
      <TodaysPick client:only="preact" />
      <PulsePlus client:idle />

      <div class="section home-doors-section">
        <div class="home-doors">
          {primaryDoors.map((door) => (
            <article class="home-door">
              <span class="home-door-label">{door.title}</span>
              <span class="home-door-title">{door.subtitle}</span>
              <span class="home-door-body">{door.body}</span>
              {door.meta && <span class="home-door-meta">{door.meta}</span>}
              <div class="home-door-actions">
                {door.ctas.map((cta) => (
                  <a class="home-door-cta" href={cta.href} aria-label={`${cta.action} ${cta.label}`}>
                    <span class="home-door-cta-title">{cta.label}</span>
                    <span class="home-door-cta-action">{cta.action} →</span>
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="section home-preview-section">
        <div class="sec-hd">
          <h2 class="sec-title">Preview the <em>Library</em></h2>
          <a class="va" href="/library">Browse the Library →</a>
        </div>
        <div class="grid-auto home-preview-grid">
          {foundationItems.map((item) => <LibraryCard item={item} preview />)}
        </div>
      </div>

      <div class="section home-preview-section">
        <div class="sec-hd">
          <h2 class="sec-title">Preview the <em>Texts</em></h2>
          <a class="va" href="/texts">View all texts →</a>
        </div>
        <div class="grid-auto home-preview-grid">
          {previewTexts.map((item) => <TextCard item={item} preview />)}
        </div>
      </div>

      <div class="section home-preview-section">
        <div class="sec-hd">
          <h2 class="sec-title">Preview the <em>Toolkit</em></h2>
          <a class="va" href="/toolkit">Use the Toolkit →</a>
        </div>
        <div class="grid-auto home-preview-grid">
          {previewToolkit.map((item) => <ToolkitCard item={item} preview />)}
        </div>
      </div>

      <div class="section home-deeper-section">
        <div class="sec-hd">
          <h2 class="sec-title">Trace the <em>Paths</em></h2>
          <a class="va" href="/paths">Follow all paths →</a>
        </div>
        <div class="grid3">
          {deeperCards.map((card) => (
            <a class="card" href={card.href}>
              <div class="card-title">{card.title}</div>
              <div class="card-desc card-desc--top">{card.desc}</div>
              <div class="card-ft">
                <span class="card-meta">{card.meta}</span>
                <span class="card-cta">{card.cta}</span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="section home-deeper-section">
        <div class="sec-hd">
          <h2 class="sec-title">From <em>Hiei</em></h2>
        </div>
        <div class="hiei-links">
          <a class="hiei-link" href="/stack">
            <span class="hiei-link-title">Stack</span>
            <span class="hiei-link-desc">How I hold Bitcoin — not how much, but how and why.</span>
            <span class="hiei-link-cta">Read →</span>
          </a>
          <a class="hiei-link" href="/questions">
            <span class="hiei-link-title">Questions</span>
            <span class="hiei-link-desc">Reader questions, answered when I have something worth saying.</span>
            <span class="hiei-link-cta">Read →</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .ph-meta {
    margin-top: var(--sp-4);
    color: var(--tx-3);
    font-family: var(--font-body);
    font-size: var(--fz-sm);
    line-height: var(--lh-relaxed);
  }

  /* Homepage ph — no border, reduced bottom padding since Today's Pick follows */
  :global(.page .ph) {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: var(--sp-6);
  }

  .home-divider {
    width: 100%;
    height: 1px;
    background: var(--bdr);
    margin-bottom: var(--sp-9);
  }

  .home-doors-section {
    padding-top: var(--sp-12);
    padding-bottom: var(--sp-10);
  }

  .home-doors {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  .home-door {
    min-height: 300px;
    display: flex;
    flex-direction: column;
    padding: var(--sp-6);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    background: var(--surf);
    color: inherit;
    transition: border-color var(--ease-card), background var(--ease-card);
  }

  .home-door:focus-within,
  .home-door:hover {
    border-color: var(--bdr-2);
    background: var(--surf-2);
  }

  .home-door-label,
  .home-door-meta {
    font-family: var(--font-body);
    font-size: var(--fz-3xs);
    font-weight: var(--fw-semi);
    letter-spacing: var(--ls-7);
    text-transform: uppercase;
  }

  .home-door-label {
    color: var(--gold-hi);
    margin-bottom: var(--sp-3);
  }

  .home-door-title {
    font-family: var(--font-body);
    font-size: var(--fz-2xl);
    line-height: var(--lh-snug);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-snug);
    margin-bottom: var(--sp-4);
  }

  .home-door-body {
    font-family: var(--font-body);
    font-size: var(--fz-base);
    line-height: var(--lh-relaxed);
    color: var(--tx-2);
    flex: 1;
  }

  .home-door-meta {
    color: var(--tx-3);
    margin-top: var(--sp-4);
  }

  .home-door-actions {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: var(--sp-6);
    border-top: 1px solid var(--bdr);
  }

  .home-door-cta {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding: var(--sp-3) 0;
    border: 0;
    border-bottom: 1px solid var(--bdr);
    border-radius: 0;
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--fz-xs);
    font-weight: var(--fw-semi);
    letter-spacing: var(--ls-5);
    line-height: var(--lh-snug);
    text-transform: uppercase;
    color: inherit;
  }

  .home-door-cta:last-child {
    border-bottom: 0;
  }

  .home-door-cta-title {
    color: var(--tx);
  }

  .home-door-cta-action {
    color: var(--gold);
  }

  .home-preview-section {
    padding: var(--sp-9) 0;
  }

  .home-preview-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .home-preview-grid .card {
    background: transparent;
  }

  .hiei-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }

  .hiei-link {
    display: flex;
    flex-direction: column;
    padding: var(--sp-6) var(--sp-6);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    transition: border-color var(--ease-card), background var(--ease-card);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .hiei-link:hover {
    border-color: var(--bdr-2);
    background: var(--surf);
  }

  .hiei-link-title {
    font-family: var(--font-body);
    font-size: var(--fz-lg);
    font-weight: var(--fw-semi);
    letter-spacing: var(--ls-normal);
    margin-bottom: var(--sp-2);
  }

  .hiei-link-desc {
    font-family: var(--font-body);
    font-size: var(--fz-base);
    color: var(--tx-2);
    line-height: var(--lh-relaxed);
    flex: 1;
    margin-bottom: var(--sp-3);
  }

  .hiei-link-cta {
    font-family: var(--font-body);
    font-size: var(--fz-xs);
    font-weight: var(--fw-semi);
    color: var(--gold);
    letter-spacing: var(--ls-5);
    text-transform: uppercase;
    align-self: flex-end;
    margin-top: auto;
    padding-top: var(--sp-3);
    border-top: 1px solid var(--bdr);
  }

  .home-deeper-section {
    margin-left: calc(-1 * var(--pad));
    margin-right: calc(-1 * var(--pad));
    padding-left: var(--pad);
    padding-right: var(--pad);
    border-radius: var(--radius);
  }

  .home-deeper-section + .home-deeper-section {
    margin-top: var(--sp-6);
  }

  @media (max-width: 640px) {
    .home-doors,
    .home-preview-grid {
      grid-template-columns: 1fr;
    }

    .home-door-cta {
      width: 100%;
    }

    .hiei-links {
      grid-template-columns: 1fr;
    }
  }
</style>
