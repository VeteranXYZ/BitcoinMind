---
import Base from '@/layouts/Base.astro';
import LibraryCard from '@/components/LibraryCard.astro';
import TextCard from '@/components/TextCard.astro';
import ToolkitCard from '@/components/ToolkitCard.astro';
import TodaysPick from '@/components/TodaysPick';
import PulsePlus from '@/components/PulsePlus';
import { LIBRARY } from '@/data/library';
import { TEXTS } from '@/data/texts';
import { TOOLKIT } from '@/data/toolkit';
import { SITE } from '@/lib/seo';

const foundationItems = LIBRARY.filter((item) => item.layer === 1).slice(0, 2);
const previewTexts = TEXTS.slice(0, 2);
const previewToolkit = TOOLKIT.slice(0, 2);
const textCount = TEXTS.length;
const primaryDoors = [
  {
    title: 'Start',
    subtitle: 'The Source Primer',
    body: 'Five steps from the original paper to money, sovereignty, and a personal 2011 note.',
    ctas: [
      { href: '/primer', label: 'Primer', action: 'Begin' },
    ],
  },
  {
    title: 'Study',
    subtitle: 'Library + Texts',
    body: 'Books and writings arranged for monetary, technical, and sovereignty study.',
    meta: `${LIBRARY.length} library items · ${textCount} texts`,
    ctas: [
      { href: '/library', label: 'Library', meta: `${LIBRARY.length} items`, action: 'Browse' },
      { href: '/texts', label: 'Texts', meta: `${textCount} texts`, action: 'Read' },
    ],
  },
  {
    title: 'Practice',
    subtitle: 'Toolkit + Paths',
    body: 'Tools and learning routes for observation, verification, custody, and deeper study.',
    meta: `${TOOLKIT.length} tools · 5 paths`,
    ctas: [
      { href: '/toolkit', label: 'Toolkit', meta: `${TOOLKIT.length} tools`, action: 'Use' },
      { href: '/rabbit-holes', label: 'Paths', meta: '5 paths', action: 'Follow' },
    ],
  },
];

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.tagline,
  author: { '@type': 'Person', name: SITE.author },
};
---
<Base
  title={SITE.name}
  description={SITE.tagline}
  path="/"
  jsonLd={websiteLd}
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">bitcoinmind.com</div>
        <h1 class="ph-title">Bitcoin<em>Mind</em></h1>
        <p class="ph-desc">A personal map for studying Bitcoin as money, protocol, and sovereignty.</p>
        <p class="ph-meta">By Hiei · Since 2017</p>
      </div>

      <TodaysPick client:only="preact" />
      <PulsePlus client:idle />

      <div class="section home-doors-section">
        <div class="home-doors">
          {primaryDoors.map((door) => (
            <article class="home-door">
              <span class="home-door-label">{door.title}</span>
              <span class="home-door-title">{door.subtitle}</span>
              <span class="home-door-body">{door.body}</span>
              {door.meta && <span class="home-door-meta">{door.meta}</span>}
              <div class="home-door-actions">
                {door.ctas.map((cta) => (
                  <a class="home-door-cta" href={cta.href} aria-label={`${cta.action} ${cta.label}`}>
                    <span class="home-door-cta-title">{cta.label}</span>
                    {'meta' in cta && cta.meta && <span class="home-door-cta-meta">{cta.meta}</span>}
                    <span class="home-door-cta-action">{cta.action}</span>
                    <span class="home-door-cta-arrow" aria-hidden="true">→</span>
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="section home-preview-section">
        <div class="sec-hd">
          <h2 class="sec-title">Preview the <em>Library</em></h2>
          <a class="va" href="/library">Open the Library →</a>
        </div>
        <div class="grid-auto home-preview-grid">
          {foundationItems.map((item) => <LibraryCard item={item} preview />)}
        </div>
      </div>

      <div class="section home-preview-section">
        <div class="sec-hd">
          <h2 class="sec-title">Preview the <em>Texts</em></h2>
          <a class="va" href="/texts">View all {textCount} texts →</a>
        </div>
        <div class="grid-auto home-preview-grid">
          {previewTexts.map((item) => <TextCard item={item} preview />)}
        </div>
      </div>

      <div class="section home-preview-section">
        <div class="sec-hd">
          <h2 class="sec-title">Preview the <em>Toolkit</em></h2>
          <a class="va" href="/toolkit">Open the Toolkit →</a>
        </div>
        <div class="grid-auto home-preview-grid">
          {previewToolkit.map((item) => <ToolkitCard item={item} preview />)}
        </div>
      </div>

      <div class="section">
        <div class="sec-hd">
          <h2 class="sec-title">Go <em>Deeper</em></h2>
          <a class="va" href="/rabbit-holes">View all paths →</a>
        </div>
        <div class="grid3">
          <a class="card" href="/timeline">
            <div class="card-layer">Chronology</div>
            <div class="card-title">Timeline</div>
            <div class="card-desc card-desc--top">Seventeen years of signal. The ideas and events that shaped Bitcoin, from the whitepaper to the present block.</div>
            <div class="card-ft">
              <span class="card-meta">16 events</span>
              <span class="card-cta">EXPLORE →</span>
            </div>
          </a>
          <a class="card" href="/glossary">
            <div class="card-layer">Concepts</div>
            <div class="card-title">Glossary</div>
            <div class="card-desc card-desc--top">Not definitions — conceptual anchors. Each entry is a compact note on a core Bitcoin idea.</div>
            <div class="card-ft">
              <span class="card-meta">15 terms</span>
              <span class="card-cta">READ →</span>
            </div>
          </a>
          <a class="card" href="/debates">
            <div class="card-layer">Objections</div>
            <div class="card-title">Objections</div>
            <div class="card-desc card-desc--top">The strongest arguments against Bitcoin, answered without pretending they are weak.</div>
            <div class="card-ft">
              <span class="card-meta">6 objections</span>
              <span class="card-cta">READ →</span>
            </div>
          </a>
        </div>
      </div>

      <div class="section">
        <div class="sec-hd">
          <h2 class="sec-title">From <em>Hiei</em></h2>
        </div>
        <div class="hiei-links">
          <a class="hiei-link" href="/stack">
            <span class="hiei-link-title">Stack</span>
            <span class="hiei-link-desc">How I hold Bitcoin — not how much, but how and why.</span>
            <span class="hiei-link-cta">Read →</span>
          </a>
          <a class="hiei-link" href="/questions">
            <span class="hiei-link-title">Questions</span>
            <span class="hiei-link-desc">Reader questions, answered when I have something worth saying.</span>
            <span class="hiei-link-cta">Read →</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .ph-meta {
    margin-top: var(--sp-4);
    color: var(--tx-3);
    font-family: var(--font-body);
    font-size: var(--fz-sm);
    line-height: var(--lh-relaxed);
  }

  .home-doors-section {
    padding-top: 0;
    padding-bottom: var(--sp-10);
  }

  .home-doors {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }

  .home-door {
    min-height: 300px;
    display: flex;
    flex-direction: column;
    padding: var(--sp-6);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    background: var(--surf);
    color: inherit;
    transition: border-color var(--ease-card), background var(--ease-card);
  }

  .home-door:focus-within,
  .home-door:hover {
    border-color: var(--bdr-2);
    background: var(--surf-2);
  }

  .home-door-label,
  .home-door-meta {
    font-family: var(--font-body);
    font-size: var(--fz-3xs);
    font-weight: var(--fw-semi);
    letter-spacing: var(--ls-7);
    text-transform: uppercase;
  }

  .home-door-label {
    color: var(--gold);
    margin-bottom: var(--sp-3);
  }

  .home-door-title {
    font-family: var(--font-body);
    font-size: var(--fz-2xl);
    line-height: var(--lh-snug);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-snug);
    margin-bottom: var(--sp-4);
  }

  .home-door-body {
    font-family: var(--font-body);
    font-size: var(--fz-base);
    line-height: var(--lh-relaxed);
    color: var(--tx-2);
    flex: 1;
  }

  .home-door-meta {
    color: var(--tx-3);
    margin-top: var(--sp-4);
  }

  .home-door-actions {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: var(--sp-6);
    border-top: 1px solid var(--bdr);
  }

  .home-door-cta {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: var(--sp-3);
    padding: var(--sp-3) 0;
    border: 0;
    border-bottom: 1px solid var(--bdr);
    border-radius: 0;
    background: transparent;
    color: var(--tx-2);
    font-family: var(--font-body);
    font-size: var(--fz-3xs);
    font-weight: var(--fw-semi);
    letter-spacing: var(--ls-5);
    line-height: var(--lh-snug);
    text-transform: uppercase;
    transition: color var(--ease-fast), border-color var(--ease-fast), background var(--ease-fast);
  }

  .home-door-cta:last-child {
    border-bottom: 0;
  }

  .home-door-cta-title {
    min-width: 0;
    flex: 1;
    color: var(--tx);
  }

  .home-door-cta-meta {
    color: var(--tx-3);
    font-size: var(--fz-3xs);
    flex-shrink: 0;
  }

  .home-door-cta-action {
    color: var(--tx-2);
    flex-shrink: 0;
  }

  .home-door-cta:focus-visible {
    outline: 1px solid var(--focus-ring);
    outline-offset: 4px;
  }

  .home-door-cta:hover {
    color: var(--tx);
    border-color: var(--border-accent);
  }

  .home-door-cta:hover .home-door-cta-action {
    color: var(--tx);
  }

  .home-door-cta-arrow {
    color: var(--gold);
    transition: color var(--ease-fast), transform var(--ease-fast);
  }

  .home-door-cta:hover .home-door-cta-arrow {
    color: var(--gold-hi);
    transform: translateX(2px);
  }

  .home-preview-section {
    padding: var(--sp-9) 0;
  }

  .home-preview-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .home-preview-grid .card {
    background: transparent;
  }

  .hiei-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }

  .hiei-link {
    display: flex;
    flex-direction: column;
    padding: var(--sp-6) var(--sp-6);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    transition: border-color var(--ease-card), background var(--ease-card);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .hiei-link:hover {
    border-color: var(--bdr-2);
    background: var(--surf);
  }

  .hiei-link-title {
    font-family: var(--font-body);
    font-size: var(--fz-lg);
    font-weight: var(--fw-semi);
    letter-spacing: var(--ls-normal);
    margin-bottom: var(--sp-2);
  }

  .hiei-link-desc {
    font-family: var(--font-body);
    font-size: var(--fz-base);
    color: var(--tx-2);
    line-height: var(--lh-relaxed);
    flex: 1;
    margin-bottom: var(--sp-3);
  }

  .hiei-link-cta {
    font-family: var(--font-body);
    font-size: var(--fz-3xs);
    font-weight: var(--fw-semi);
    color: var(--gold);
    letter-spacing: var(--ls-5);
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .home-doors,
    .home-preview-grid {
      grid-template-columns: 1fr;
    }

    .home-door-cta {
      width: 100%;
    }

    .hiei-links {
      grid-template-columns: 1fr;
    }
  }
</style>
