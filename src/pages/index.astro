---
import Base from '@/layouts/Base.astro';
import LibraryCard from '@/components/LibraryCard.astro';
import TextCard from '@/components/TextCard.astro';
import ToolkitCard from '@/components/ToolkitCard.astro';
import TodaysPick from '@/components/TodaysPick';
import PulsePlus from '@/components/PulsePlus';
import { LIBRARY } from '@/data/library';
import { TEXTS } from '@/data/texts';
import { TOOLKIT } from '@/data/toolkit';
import { SITE } from '@/lib/seo';

const foundationItems = LIBRARY.filter((item) => item.layer === 1).slice(0, 2);
const previewTexts = TEXTS.slice(0, 2);
const previewToolkit = TOOLKIT.slice(0, 2);
const textCount = TEXTS.length;
const primaryDoors = [
  {
    label: 'Start',
    title: 'Primer',
    body: 'A five-step path for approaching Bitcoin seriously before branching into the larger map.',
    href: '/primer',
    meta: '5 steps',
  },
  {
    label: 'Study',
    title: 'Library + Texts',
    body: 'Books and primary writings arranged for monetary, technical, and sovereignty study.',
    href: '/library',
    meta: `${LIBRARY.length} library items · ${textCount} texts`,
  },
  {
    label: 'Practice',
    title: 'Toolkit + Paths',
    body: 'Tools and learning routes for observation, verification, custody, and deeper study.',
    href: '/toolkit',
    meta: `${TOOLKIT.length} tools · 5 paths`,
  },
];

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.tagline,
  author: { '@type': 'Person', name: SITE.author },
};
---
<Base
  title={SITE.name}
  description={SITE.tagline}
  path="/"
  jsonLd={websiteLd}
>
  <div class="page">
    <div class="hero">
      <div class="c">
        <div class="hero-eye">bitcoinmind.com</div>
        <h1 class="hero-title">
          <span class="hero-t1">Bitcoin</span>
          <span class="hero-t2">Mind</span>
        </h1>
        <div class="hero-rule"><div class="hero-rule-dot"></div></div>
        <p class="hero-quote">A personal map for studying Bitcoin as money, protocol, and sovereignty.</p>
        <p class="hero-by">A public record by {SITE.author} · est. 2017</p>
        <TodaysPick client:only="preact" />
        <PulsePlus client:idle />
      </div>
    </div>

    <div class="c">
      <div class="section home-doors-section">
        <div class="home-doors">
          {primaryDoors.map((door) => (
            <a class="home-door" href={door.href}>
              <span class="home-door-label">{door.label}</span>
              <span class="home-door-title">{door.title}</span>
              <span class="home-door-body">{door.body}</span>
              <span class="home-door-meta">{door.meta}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="section home-preview-section">
        <div class="sec-hd">
          <h2 class="sec-title">Preview the <em>Library</em></h2>
          <a class="va" href="/library">Open the Library →</a>
        </div>
        <div class="grid-auto home-preview-grid">
          {foundationItems.map((item) => <LibraryCard item={item} preview />)}
        </div>
      </div>

      <div class="section home-preview-section">
        <div class="sec-hd">
          <h2 class="sec-title">Preview the <em>Texts</em></h2>
          <a class="va" href="/texts">View all {textCount} texts →</a>
        </div>
        <div class="grid-auto home-preview-grid">
          {previewTexts.map((item) => <TextCard item={item} preview />)}
        </div>
      </div>

      <div class="section home-preview-section">
        <div class="sec-hd">
          <h2 class="sec-title">Preview the <em>Toolkit</em></h2>
          <a class="va" href="/toolkit">Open the Toolkit →</a>
        </div>
        <div class="grid-auto home-preview-grid">
          {previewToolkit.map((item) => <ToolkitCard item={item} preview />)}
        </div>
      </div>

      <div class="section">
        <div class="sec-hd">
          <h2 class="sec-title">Go <em>Deeper</em></h2>
          <a class="va" href="/rabbit-holes">View all paths →</a>
        </div>
        <div class="grid3">
          <a class="card" href="/timeline">
            <div class="card-layer">Chronology</div>
            <div class="card-title">Timeline</div>
            <div class="card-desc card-desc--top">Seventeen years of signal. The ideas and events that shaped Bitcoin, from the whitepaper to the present block.</div>
            <div class="card-ft">
              <span class="card-meta">16 events</span>
              <span class="card-cta">EXPLORE →</span>
            </div>
          </a>
          <a class="card" href="/glossary">
            <div class="card-layer">Concepts</div>
            <div class="card-title">Glossary</div>
            <div class="card-desc card-desc--top">Not definitions — conceptual anchors. Each entry is a compact note on a core Bitcoin idea.</div>
            <div class="card-ft">
              <span class="card-meta">15 terms</span>
              <span class="card-cta">READ →</span>
            </div>
          </a>
          <a class="card" href="/debates">
            <div class="card-layer">Objections</div>
            <div class="card-title">Objections</div>
            <div class="card-desc card-desc--top">The strongest arguments against Bitcoin, answered without pretending they are weak.</div>
            <div class="card-ft">
              <span class="card-meta">6 objections</span>
              <span class="card-cta">READ →</span>
            </div>
          </a>
        </div>
      </div>

      <div class="section">
        <div class="sec-hd">
          <h2 class="sec-title">From <em>Hiei</em></h2>
        </div>
        <div class="hiei-links">
          <a class="hiei-link" href="/stack">
            <span class="hiei-link-title">Stack</span>
            <span class="hiei-link-desc">How I hold Bitcoin — not how much, but how and why.</span>
            <span class="hiei-link-cta">Read →</span>
          </a>
          <a class="hiei-link" href="/questions">
            <span class="hiei-link-title">Questions</span>
            <span class="hiei-link-desc">Reader questions, answered when I have something worth saying.</span>
            <span class="hiei-link-cta">Read →</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .home-doors-section {
    padding-top: var(--sp-10);
    padding-bottom: var(--sp-10);
  }

  .home-doors {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }

  .home-door {
    min-height: 220px;
    display: flex;
    flex-direction: column;
    padding: var(--sp-6);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    background: var(--surf);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--ease-card), background var(--ease-card);
  }

  .home-door:hover {
    border-color: var(--gold);
    background: var(--surf-2);
  }

  .home-door-label,
  .home-door-meta {
    font-family: var(--font-mono);
    font-size: var(--fz-3xs);
    letter-spacing: var(--ls-7);
    text-transform: uppercase;
  }

  .home-door-label {
    color: var(--gold);
    margin-bottom: var(--sp-3);
  }

  .home-door-title {
    font-family: var(--font-serif);
    font-size: var(--fz-2xl);
    line-height: var(--lh-snug);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-snug);
    margin-bottom: var(--sp-4);
  }

  .home-door-body {
    font-family: var(--font-body);
    font-size: var(--fz-base);
    line-height: var(--lh-relaxed);
    color: var(--tx-2);
    flex: 1;
  }

  .home-door-meta {
    color: var(--tx-3);
    margin-top: var(--sp-5);
  }

  .home-preview-section {
    padding: var(--sp-9) 0;
  }

  .home-preview-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .home-preview-grid .card {
    background: transparent;
  }

  .hiei-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }

  .hiei-link {
    display: flex;
    flex-direction: column;
    padding: var(--sp-6) var(--sp-6);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    transition: border-color var(--ease-card), background var(--ease-card);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .hiei-link:hover {
    border-color: var(--gold);
    background: var(--surf);
  }

  .hiei-link-title {
    font-family: var(--font-serif);
    font-size: var(--fz-lg);
    font-weight: var(--fw-semi);
    letter-spacing: var(--ls-normal);
    margin-bottom: var(--sp-2);
  }

  .hiei-link-desc {
    font-family: var(--font-body);
    font-size: var(--fz-base);
    color: var(--tx-2);
    line-height: var(--lh-relaxed);
    flex: 1;
    margin-bottom: var(--sp-3);
  }

  .hiei-link-cta {
    font-family: var(--font-mono);
    font-size: var(--fz-3xs);
    color: var(--gold);
    letter-spacing: var(--ls-5);
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .home-doors,
    .home-preview-grid {
      grid-template-columns: 1fr;
    }
    .hiei-links {
      grid-template-columns: 1fr;
    }
  }
</style>
