---
import Base from '@/layouts/Base.astro';

interface Step {
  n: string;
  head: string;
  body: string;
  label: string;
  author: string | null;
  href: string;
  external: boolean;
}

const steps: Step[] = [
  { n: '1', head: 'Read the document that began everything.',
    body: "Nine pages. Written by a person no one has ever identified. Read it not to understand the cryptography — read it to feel the problem it's solving. Two people. No bank in between. That's the whole idea.",
    label: 'Bitcoin: A Peer-to-Peer Electronic Cash System', author: 'Satoshi Nakamoto',
    href: 'https://bitcoin.org/bitcoin.pdf', external: true },
  { n: '2', head: 'Learn what money actually is.',
    body: "You cannot understand what Bitcoin is replacing without understanding what money is. Most people never ask. The Bitcoin Standard is where I'd begin — not the whole work, just Part One. The history of money is the only context that makes Bitcoin legible.",
    label: 'The Bitcoin Standard', author: 'Saifedean Ammous',
    href: 'https://saifedean.com/tbs/', external: true },
  { n: '3', head: 'Understand the monetary case.',
    body: "Bitcoin is easiest to misunderstand when it is treated as one project inside a broad crypto category. Parker Lewis frames it through monetary properties, credibility, and network effects. Read Gradually, Then Suddenly before you decide where Bitcoin belongs.",
    label: 'Gradually, Then Suddenly', author: 'Parker Lewis',
    href: 'https://unchained.com/gradually-then-suddenly/', external: true },
  { n: '4', head: 'Consider the question of sovereignty.',
    body: "If the first three steps landed, you'll feel it — something shifts in how you think about savings, governments, time, sovereignty. The Sovereign Individual was written in 1997. It has no business being this accurate about the present. Read it slowly.",
    label: 'The Sovereign Individual', author: 'Davidson & Rees-Mogg',
    href: 'https://www.amazon.com/Sovereign-Individual-Mastering-Transition-Information/dp/0684832720', external: true },
  { n: '5', head: 'Read what I actually think.',
    body: "The Notes section is where I write without a net. Begin with the first entry — April 2011, Bitcoin at $1. I called it devil-like. I wasn't wrong about the nature of it. I was wrong about what to do.",
    label: 'Notes', author: null, href: '/notes', external: false },
];
---
<Base
  title="Bitcoin Primer"
  description="A five-step Bitcoin learning path for readers who want to understand the whitepaper, money, Bitcoin's monetary case, sovereignty, and self-custody."
  path="/primer"
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">Primer</div>
        <h1 class="ph-title">The BitcoinMind <em>Primer</em></h1>
        <p class="ph-desc">Five steps for approaching Bitcoin seriously: the document, the problem of money, the monetary case, sovereignty, and my own record.</p>
      </div>

      <div class="steps-wrap">
        {steps.map((s) => (
          <div class="step">
            <div class="step-num-row">
              <span class="step-num-badge">{s.n}</span>
              <span class="step-num-line"></span>
            </div>
            <h2 class="step-heading">{s.head}</h2>
            <p class="step-body">{s.body}</p>
            <a
              class="step-cta"
              href={s.href}
              {...(s.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <span class="step-arrow">→</span>
              <span>
                <span class="step-resource">{s.label}</span>
                {s.author && <span class="step-auth">{s.author}</span>}
              </span>
            </a>
          </div>
        ))}

        <div class="steps-closing">
          <p class="steps-closing-p">That's enough.</p>
          <p class="steps-closing-p steps-closing-p--gap">The full library is here when you want it. But these five are the ones I'd give to someone I wanted to help approach Bitcoin seriously — not that Bitcoin is a good investment, but that it's a serious idea worth your serious attention.</p>
          <div class="steps-signature">— Hiei</div>
        </div>
      </div>
    </div>
  </div>
</Base>
