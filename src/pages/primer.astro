---
import Base from '@/layouts/Base.astro';
import StudyLoop from '@/components/StudyLoop.astro';
import StudyNext from '@/components/StudyNext.astro';
import { SITE } from '@/lib/seo';

interface Step {
  n: string;
  head: string;
  body: string;
  label: string;
  author: string | null;
  time: string;
  href: string;
  external: boolean;
}

const steps: Step[] = [
  { n: '01', head: 'Begin with the problem, not the asset.',
    body: 'Money coordinates strangers across time. Before asking whether Bitcoin has value, ask why societies adopt monetary goods, why settlement requires trust, and what happens when the rules of money can change. This keeps price from becoming the explanation.',
    label: 'Shelling Out: The Origins of Money', author: 'Nick Szabo', time: '40 min',
    href: '/texts#shelling-out', external: false },
  { n: '02', head: 'Read the proposal in its own words.',
    body: 'The whitepaper proposes a way to order electronic payments without a trusted central operator. Read it once for the problem and structure, not mastery. Notice what it claims, what it leaves to implementation, and what later Bitcoin culture has added.',
    label: 'Bitcoin: A Peer-to-Peer Electronic Cash System', author: 'Satoshi Nakamoto', time: '20 min',
    href: '/texts#bitcoin-whitepaper', external: false },
  { n: '03', head: 'Replace metaphors with mechanisms.',
    body: 'Scarcity is not secured by a slogan. It emerges from transaction rules, proof of work, difficulty adjustment, incentives, and users independently rejecting invalid history. Learn enough of the machinery to explain where trust was reduced — and where it remains.',
    label: 'Inventing Bitcoin', author: 'Yan Pritzker', time: '2 hrs',
    href: '/library#inventing-bitcoin', external: false },
  { n: '04', head: 'Move from belief to verification.',
    body: 'A block explorer lets you observe someone else’s view. A validating node checks the rules for itself. Then custody asks a harder question: if no intermediary can reverse the payment, which mistakes and recovery duties become yours?',
    label: 'Verification and custody tools', author: null, time: '45–90 min',
    href: '/toolkit', external: false },
  { n: '05', head: 'Try to disprove the thesis.',
    body: 'A serious view of Bitcoin must survive energy costs, volatility, regulation, governance, cryptographic risk, and the burden of self-custody. The goal is not instant conviction. It is a position precise enough to be revised when evidence changes.',
    label: 'Honest Objections', author: null, time: '30 min',
    href: '/objections', external: false },
];
const primerLd = {
  '@context': 'https://schema.org',
  '@type': 'LearningResource',
  name: 'The First-Principles Bitcoin Primer',
  description: 'A five-step introduction to money, the Bitcoin protocol, verification, custody, and serious objections.',
  url: `${SITE.url}/primer`,
  inLanguage: 'en',
  educationalLevel: 'Beginner',
  teaches: [
    'Why money and settlement require trust',
    'How Bitcoin transactions and proof of work fit together',
    'The difference between observing and verifying Bitcoin',
    'The tradeoffs of Bitcoin self-custody',
    'How to evaluate serious objections to Bitcoin',
  ],
};
---
<Base
  title="Bitcoin Primer"
  metaTitle="What Is Bitcoin? A First-Principles Primer — BitcoinMind"
  description="Understand Bitcoin from first principles in five steps: money, the whitepaper, protocol mechanics, verification, self-custody, and serious objections."
  ogTitle="The First-Principles Bitcoin Primer"
  ogDescription="Five questions for understanding Bitcoin without price hype, tribal slogans, or borrowed conviction."
  twitterTitle="The First-Principles Bitcoin Primer"
  twitterDescription="Money, protocol, verification, custody, and objections—in the order that makes Bitcoin intelligible."
  path="/primer"
  jsonLd={primerLd}
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">Primer</div>
        <h1 class="ph-title">The First-Principles <em>Primer</em></h1>
        <p class="ph-desc">Five questions for understanding Bitcoin without price hype, tribal slogans, or borrowed conviction.</p>
      </div>

      <StudyLoop active="orient" />

      <div class="steps-wrap">
        {steps.map((s) => (
          <div class="step">
            <div class="step-num-row">
              <span class="step-num-badge">{s.n}</span>
              <span class="step-num-line"></span>
            </div>
            <h2 class="step-heading">{s.head}</h2>
            <p class="step-body">{s.body}</p>
            <a
              class="step-cta"
              href={s.href}
              {...(s.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <span class="step-arrow">→</span>
              <span>
                <span class="step-resource">{s.label}</span>
                <span class="step-auth">{s.author ? `${s.author} · ${s.time}` : s.time}</span>
              </span>
            </a>
          </div>
        ))}

        <div class="steps-closing">
          <div class="steps-closing-eye">End of Primer · 5 steps</div>
          <h2 class="steps-closing-lead">Now choose what to test.</h2>

          <p class="steps-closing-p">
            The primer is an orientation, not a conclusion. If the monetary
            question is strongest, follow the Money path. If the mechanism is
            still unclear, follow Protocol. If ownership is the point, study
            verification and custody before moving meaningful value.
          </p>

          <div class="steps-closing-sig">
            <span class="steps-closing-sig-name">— Hiei</span>
            <span class="steps-closing-sig-meta">Curator, BitcoinMind</span>
          </div>
        </div>
      </div>
      <StudyNext next={{ href: '/paths', label: 'Study Paths', description: 'Choose a question-led route and make the learning outcome explicit.' }} />
    </div>
  </div>
</Base>

<style>
  /* ── Closing block ──
     A proper editorial close: eyebrow label establishes the end of
     the primer, display headline carries the weight, one paragraph
     sets the tone, and the signature is anchored bottom-right in
     gold — the curator's mark. */
  .steps-closing {
    margin-top: var(--sp-9);
    padding-top: var(--sp-8);
    border-top: 1px solid var(--bdr);
  }

  .steps-closing-eye {
    font-family: var(--font-mono);
    font-size: var(--fz-xs);
    color: var(--gold-hi);
    letter-spacing: var(--ls-11);
    text-transform: uppercase;
    margin-bottom: var(--sp-5);
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    line-height: 1;
  }
  .steps-closing-eye::before {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--gold-hi);
    flex-shrink: 0;
  }

  .steps-closing-lead {
    font-family: var(--font-display);
    font-size: var(--fz-page);
    font-weight: var(--fw-bold);
    line-height: var(--lh-title);
    letter-spacing: var(--ls-tighter);
    color: var(--tx);
    margin-bottom: var(--sp-6);
  }

  .steps-closing .steps-closing-p {
    font-family: var(--font-body);
    font-size: var(--fz-lg);
    line-height: var(--lh-loose);
    color: var(--tx-2);
    max-width: 100%;
    margin-bottom: var(--sp-9);
  }

  /* Signature — anchored bottom-right, gold, curator's mark */
  .steps-closing-sig {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    gap: var(--sp-1);
  }

  .steps-closing-sig-name {
    font-family: var(--font-display);
    font-size: var(--fz-lg);
    font-style: italic;
    font-weight: var(--fw-semi);
    color: var(--gold-hi);
    letter-spacing: var(--ls-snug);
  }

  .steps-closing-sig-meta {
    font-family: var(--font-body);
    font-size: var(--fz-3xs);
    color: var(--gold);
    letter-spacing: var(--ls-7);
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .steps-closing-lead {
      font-size: var(--fz-3xl);
    }
    .steps-closing .steps-closing-p {
      font-size: var(--fz-md);
    }
  }
</style>
