---
import Base from '@/layouts/Base.astro';
import { DEBATES } from '@/data/debates';
---
<Base
  title="Objections"
  description="The strongest arguments against Bitcoin, answered without pretending they are weak."
  path="/debates"
>
  <div class="page">
    <div class="c">
      <div class="ph">
        <div class="ph-eye">Objections</div>
        <h1 class="ph-title">Honest <em>Objections</em></h1>
        <p class="ph-desc">The strongest arguments against Bitcoin, answered without pretending they are weak.</p>
      </div>

      <div class="db-list">
        {DEBATES.map((d, i) => (
          <div class="db-item" id={d.id}>
            <div class="db-num-row">
              <span class="db-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="db-num-line" />
              <h2 class="db-title">{d.title}</h2>
            </div>

            <div class="db-grid">
              <div class="db-col db-col--obj">
                <div class="db-col-lbl">The Objection</div>
                <p class="db-col-body">{d.objection}</p>
              </div>
              <div class="db-col db-col--right">
                <div class="db-col-lbl">What this objection gets right</div>
                <p class="db-col-body db-col-body--gets">{d.getsRight}</p>
              </div>
              <div class="db-col db-col--res">
                <div class="db-col-lbl">The Response</div>
                <p class="db-col-body">{d.response}</p>
              </div>
            </div>

            {d.further && (
              <div class="db-further">
                <span class="db-further-lbl">Further reading</span>
                {d.further.map((l) => (
                  <a class="db-further-link" href={l.href}>{l.label} →</a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</Base>

<style>
  .db-list {
    padding-bottom: var(--sp-12);
  }

  .db-item {
    margin-bottom: var(--sp-11);
  }

  .db-num-row {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-6);
  }

  .db-num {
    font-family: var(--font-mono);
    font-size: var(--fz-3xs);
    color: var(--gold);
    letter-spacing: var(--ls-7);
    border: 1px solid var(--gold);
    padding: 3px var(--sp-2);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .db-num-line {
    height: 1px;
    flex: 1;
    background: var(--bdr);
  }

  .db-title {
    font-family: var(--font-body);
    font-size: var(--fz-2xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-snug);
    flex-shrink: 0;
  }

  .db-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }

  .db-col {
    padding: var(--sp-7);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
  }

  .db-col--obj {
    background: var(--bg-deep);
  }

  .db-col--res {
    background: var(--surf);
    border-left: 3px solid var(--gold);
  }

  .db-col--right {
    background: var(--surf);
  }

  .db-col-lbl {
    font-family: var(--font-body);
    font-size: var(--fz-3xs);
    font-weight: var(--fw-semi);
    letter-spacing: var(--ls-9);
    text-transform: uppercase;
    margin-bottom: var(--sp-4);
  }

  .db-col--obj .db-col-lbl {
    color: var(--tx-3);
  }

  .db-col--res .db-col-lbl,
  .db-col--right .db-col-lbl {
    color: var(--gold);
  }

  .db-col-body {
    font-family: var(--font-body);
    font-size: var(--fz-md);
    line-height: var(--lh-loose);
    color: var(--tx-2);
  }

  .db-col-body--gets {
    color: var(--tx-3);
  }

  .db-further {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-top: var(--sp-4);
    padding-top: var(--sp-3);
  }

  .db-further-lbl {
    font-family: var(--font-body);
    font-size: var(--fz-3xs);
    font-weight: var(--fw-semi);
    color: var(--tx-3);
    letter-spacing: var(--ls-7);
    text-transform: uppercase;
  }

  .db-further-link {
    font-family: var(--font-body);
    font-size: var(--fz-xs);
    font-weight: var(--fw-semi);
    color: var(--gold);
    letter-spacing: var(--ls-3);
    transition: color var(--ease-fast);
  }
  .db-further-link:hover {
    color: var(--gold-hi);
  }

  @media (max-width: 1024px) {
    .db-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .db-col {
      padding: var(--sp-5) var(--sp-4);
    }
    .db-further {
      flex-wrap: wrap;
      gap: var(--sp-2);
    }
  }
</style>
