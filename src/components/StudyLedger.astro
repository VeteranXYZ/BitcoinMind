<section class="study-ledger" data-study-ledger aria-labelledby="study-ledger-title">
  <div class="study-ledger-head">
    <div>
      <div class="study-ledger-eye">Local study desk</div>
      <h2 id="study-ledger-title">Continue without an account.</h2>
    </div>
    <p>Saved resources and path progress stay in this browser. Nothing is sent to BitcoinMind.</p>
  </div>
  <div class="study-resume" data-study-resume hidden>
    <span>Resume</span>
    <a data-study-resume-link href="/paths"></a>
  </div>
  <div class="study-queue-wrap">
    <h3>Study list</h3>
    <p data-study-empty>No saved resources yet. Use “Save” on Library, Texts, or Toolkit cards.</p>
    <ul class="study-queue" data-study-queue></ul>
  </div>
  <div class="study-ledger-actions study-enhanced">
    <button type="button" data-study-export>Export JSON</button>
    <label>Import JSON<input type="file" accept="application/json,.json" data-study-import /></label>
    <button type="button" data-study-clear>Clear local data</button>
  </div>
  <p class="study-ledger-status" data-study-status aria-live="polite"></p>
  <noscript><p class="study-ledger-noscript">Enable JavaScript to use the private study desk. All reading routes remain available without it.</p></noscript>
</section>

<style>
  .study-ledger { margin-bottom: var(--sp-9); padding: var(--sp-6); border: 1px solid var(--border-accent); border-radius: var(--radius); background: var(--surf); }
  .study-ledger-head { display: grid; grid-template-columns: minmax(0, 1fr) minmax(260px, 0.8fr); gap: var(--sp-8); align-items: end; margin-bottom: var(--sp-5); }
  .study-ledger-eye { font-family: var(--font-mono); font-size: var(--fz-3xs); color: var(--gold-hi); letter-spacing: var(--ls-7); text-transform: uppercase; margin-bottom: var(--sp-2); }
  .study-ledger h2 { font-family: var(--font-display); font-size: var(--fz-step); }
  .study-ledger-head p, .study-queue-wrap > p { color: var(--tx-3); font-size: var(--fz-sm); line-height: var(--lh-relaxed); }
  .study-resume { display: flex; gap: var(--sp-3); align-items: baseline; padding: var(--sp-3) 0; border-top: 1px solid var(--bdr); border-bottom: 1px solid var(--bdr); }
  .study-resume span, .study-queue-wrap h3 { font-family: var(--font-mono); font-size: var(--fz-3xs); color: var(--gold); letter-spacing: var(--ls-7); text-transform: uppercase; }
  .study-resume a { font-weight: var(--fw-semi); }
  .study-queue-wrap { padding-top: var(--sp-4); }
  .study-queue-wrap h3 { margin-bottom: var(--sp-3); }
  .study-queue { display: grid; gap: var(--sp-2); list-style: none; }
  .study-ledger-actions { display: flex; flex-wrap: wrap; gap: var(--sp-2); margin-top: var(--sp-4); padding-top: var(--sp-4); border-top: 1px solid var(--bdr); }
  .study-ledger-actions button, .study-ledger-actions label { padding: var(--sp-2) var(--sp-3); border: 1px solid var(--bdr); border-radius: var(--radius); font-size: var(--fz-xs); color: var(--tx-2); cursor: pointer; }
  .study-ledger-actions input { position: absolute; inline-size: 1px; block-size: 1px; opacity: 0; }
  .study-ledger-status, .study-ledger-noscript { margin-top: var(--sp-3); font-size: var(--fz-xs); color: var(--tx-3); }
  @media (max-width: 720px) { .study-ledger-head { grid-template-columns: 1fr; gap: var(--sp-3); } }
</style>
