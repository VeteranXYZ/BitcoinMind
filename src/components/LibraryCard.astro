---
import Tag from './Tag.astro';
import type { LibraryItem } from '@/data/types';
import { studyStageFor } from '@/lib/study';
interface Props {
  item: LibraryItem;
  preview?: boolean;
}
const { item, preview = false } = Astro.props;
const visibleTags = item.tags.slice(0, 3);
const stage = studyStageFor(item.pathStage);
---
<article class="card" id={item.id}>
  <div class="card-stage">Stage {stage.number} · {stage.label}</div>
  <div class="card-layer">{item.layerLabel}</div>
  <div class="card-role">{item.learningRole}</div>
  <div class="card-title">{item.title}</div>
  <div class="card-author">{item.author}</div>
  <div class="card-desc">{item.shortDescription}</div>
  <div class="card-tags">
    {visibleTags.map((t) => <Tag label={t} />)}
  </div>
  {!preview && (
    <details class="card-details">
      <summary>Details</summary>
      <div class="card-review">
        <div class="card-ri"><strong>Why it belongs</strong>{item.whyItBelongs}</div>
        <div class="card-ri"><strong>Best for</strong>{item.bestFor}</div>
        <div class="card-ri"><strong>Path position</strong>{item.learningPathPosition}</div>
      </div>
    </details>
  )}
  <div class="card-ft">
    <span class="card-meta">{item.difficulty}</span>
    <span class="card-actions">
      <a class="card-cta" href={item.link} target="_blank" rel="noopener noreferrer">Read →</a>
    </span>
  </div>
</article>
