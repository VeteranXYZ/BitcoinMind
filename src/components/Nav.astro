---
const navItems = [
  { href: '/primer',   label: 'Primer',    match: ['/primer'] },
  { href: '/library',   label: 'Library',   match: ['/library'] },
  { href: '/texts',  label: 'Texts',     match: ['/texts'] },
  { href: '/toolkit',   label: 'Toolkit',   match: ['/toolkit'] },
  { href: '/rabbit-holes', label: 'Paths', match: ['/rabbit-holes'] },
];

/* ── Mobile menu: grouped sections ── */
const mmGroups = [
  {
    label: 'Core',
    items: [
      { href: '/',        label: 'Home',       match: ['/'] },
      { href: '/primer',   label: 'Primer',     match: ['/primer'] },
      { href: '/library',   label: 'Library',    match: ['/library'] },
      { href: '/texts',  label: 'Texts',      match: ['/texts'] },
      { href: '/toolkit',   label: 'Toolkit',    match: ['/toolkit'] },
      { href: '/rabbit-holes', label: 'Paths', match: ['/rabbit-holes'] },
    ],
  },
  {
    label: 'Deep Dives',
    items: [
      { href: '/frames',       label: 'Frames',       match: ['/frames', '/frames/1', '/frames/2'] },
      { href: '/timeline',     label: 'Timeline',     match: ['/timeline'] },
      { href: '/glossary',     label: 'Glossary',     match: ['/glossary'] },
      { href: '/debates',      label: 'Objections',   match: ['/debates'] },
    ],
  },
  {
    label: 'Hiei',
    items: [
      { href: '/notes',     label: 'Notes',     match: ['/notes'] },
      { href: '/questions', label: 'Questions', match: ['/questions'] },
      { href: '/stack',     label: 'Stack',     match: ['/stack'] },
      { href: '/about',     label: 'About',     match: ['/about'] },
    ],
  },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (m: string[]) => m.includes(path);

/* flat counter for staggered animation delay */
let mmIdx = 0;
---
<nav>
  <div class="nav-in">
    <a class="nav-logo" href="/">Bitcoin<b>Mind</b></a>
    <div class="nav-links">
      {navItems.map((n) => (
        <a class={`nl ${isActive(n.match) ? 'on' : ''}`} href={n.href}>{n.label}</a>
      ))}
    </div>
    <button
      class="nav-menu-btn"
      data-menu-open
      aria-label="Open menu"
      aria-controls="site-menu"
      aria-expanded="false"
    >Menu</button>
  </div>
</nav>

<div id="site-menu" class="mm" role="dialog" aria-modal="true" aria-label="Site menu" data-mobile-menu hidden>
  <div class="mm-bar">
    <button class="mm-close" data-menu-close aria-label="Close menu">Close</button>
  </div>
  <nav class="mm-list" aria-label="Primary">
    {mmGroups.map((group, gi) => (
      <>
        {gi > 0 && <div class="mm-divider" />}
        <div class="mm-group-label">{group.label}</div>
        {group.items.map((n) => {
          const delay = 0.04 + (mmIdx++) * 0.022;
          return (
            <a
              class={`mm-item ${isActive(n.match) ? 'mm-item--on' : ''}`}
              href={n.href}
              data-menu-item
              style={`animation-delay: ${delay}s`}
            >
              {n.label}
            </a>
          );
        })}
      </>
    ))}
  </nav>
  <div class="mm-foot">
    <div class="mm-foot-rule"></div>
    <div class="mm-foot-l1">bitcoinmind.com · est. 2017</div>
    <div class="mm-foot-l2">A public record by Hiei</div>
  </div>
</div>
