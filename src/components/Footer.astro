---
import { SITE } from '@/lib/seo';

type FooterItem = {
  href: string;
  label: string;
  external?: boolean;
};

const footerGroups: { label: string; items: FooterItem[] }[] = [
  {
    label: 'Core',
    items: [
      { href: '/primer', label: 'Primer' },
      { href: '/paths', label: 'Paths' },
      { href: '/library', label: 'Library' },
      { href: '/texts', label: 'Texts' },
      { href: '/toolkit', label: 'Toolkit' },
    ],
  },
  {
    label: 'Lens',
    items: [
      { href: '/frames', label: 'Frames' },
      { href: '/timeline', label: 'Timeline' },
      { href: '/glossary', label: 'Glossary' },
      { href: '/objections', label: 'Objections' },
    ],
  },
  {
    label: 'Hiei',
    items: [
      { href: '/notes', label: 'Notes' },
      { href: '/questions', label: 'Questions' },
      { href: '/stack', label: 'Stack' },
      { href: '/about', label: 'About' },
      { href: '/about#privacy', label: 'Privacy' },
      { href: 'https://github.com/VeteranXYZ/BitcoinMind', label: 'GitHub', external: true },
    ],
  },
];
---
<footer>
  <div class="ft-in">
    <div class="ft-map" aria-label="Footer sitemap">
      {footerGroups.map((group) => (
        <div class="ft-map-group">
          <div class="ft-map-label">{group.label}</div>
          <div class="ft-map-links">
            {group.items.map((item) => (
              <a href={item.href} {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>{item.label}</a>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div class="ft-bottom">
      <span class="ft-copy">
        <span class="ft-seg">Since {SITE.foundedYear} · Powered by Hiei</span>
      </span>
    </div>
  </div>
</footer>
