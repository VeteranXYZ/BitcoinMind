---
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { SITE, fullTitle, canonical } from '@/lib/seo';

// Critical fonts preloaded in <head> below. The first paint uses the same
// three-family system as the rest of the site: display, body/UI, and mono.
import literata700Normal from '@fontsource/literata/files/literata-latin-700-normal.woff2?url';
import inter400Normal from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import geistMono400Normal from '@fontsource/geist-mono/files/geist-mono-latin-400-normal.woff2?url';

// Latin subset only — site is English. Keep weights deliberately narrow.
import '@fontsource/literata/latin-600.css';
import '@fontsource/literata/latin-700.css';
import '@fontsource/literata/latin-600-italic.css';
import '@fontsource/literata/latin-700-italic.css';
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/inter/latin-700.css';
import '@fontsource/geist-mono/latin-400.css';
import '@fontsource/geist-mono/latin-500.css';

import '@/styles/design-system.css';
import '@/styles/styles.css';

interface Props {
  title: string;
  description: string;
  path: string;
  metaTitle?: string;
  ogTitle?: string;
  ogDescription?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  ogType?: 'website' | 'article';
  showFooter?: boolean;
}

const {
  title,
  description,
  path,
  metaTitle,
  ogTitle,
  ogDescription,
  twitterTitle,
  twitterDescription,
  jsonLd,
  ogType = 'website',
  showFooter = true,
} = Astro.props;

const pageTitle = metaTitle ?? fullTitle(title);
const socialTitle = ogTitle ?? pageTitle;
const socialDescription = ogDescription ?? description;
const tweetTitle = twitterTitle ?? socialTitle;
const tweetDescription = twitterDescription ?? socialDescription;
const url = canonical(path);
const ldArray = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content={SITE.author} />
  <link rel="canonical" href={url} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <link rel="preload" href={literata700Normal} as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href={inter400Normal} as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href={geistMono400Normal} as="font" type="font/woff2" crossorigin="anonymous" />

  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={socialTitle} />
  <meta property="og:description" content={socialDescription} />
  <meta property="og:url" content={url} />
  <meta property="og:site_name" content={SITE.name} />

  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={tweetTitle} />
  <meta name="twitter:description" content={tweetDescription} />

  <script is:inline>
    // Hash redirect — must run before render so old SPA hash links land on the right page.
    (function () {
      var map = {
        '#home': '/', '#primer': '/primer', '#library': '/library', '#texts': '/texts',
        '#toolkit': '/toolkit', '#frames': '/frames', '#frames-1': '/frames/1',
        '#frames-2': '/frames/2', '#about': '/about', '#notes': '/notes',
        '#timeline': '/timeline', '#glossary': '/glossary', '#objections': '/objections',
        '#paths': '/paths', '#stack': '/stack', '#questions': '/questions'
      };
      var t = map[location.hash];
      if (t && location.pathname === '/') {
        location.replace(t + location.search);
      }
    })();
  </script>

  {ldArray.map((ld) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(ld)} />
  ))}
</head>
<body>
  <div id="pb"></div>
  <div class="grain" aria-hidden="true"></div>

  <Nav />

  <main>
    <slot />
  </main>

  {showFooter && <Footer />}

  <script>
    import '@/scripts/reading-progress';
    import '@/scripts/mobile-menu';
    import '@/scripts/explore-menu';
  </script>
  <script is:inline data-cfasync="false">
    (function () {
      function tokens(value) {
        return (value || '').split('|').map(function (v) { return v.trim().toLowerCase(); }).filter(Boolean);
      }

      function update(scope) {
        var active = (scope.getAttribute('data-active-filter') || 'all').toLowerCase();
        var input = scope.querySelector('[data-filter-search]');
        var query = input ? input.value.trim().toLowerCase() : '';
        var visibleCount = 0;

        scope.querySelectorAll('[data-filter-button]').forEach(function (button) {
          var isActive = (button.getAttribute('data-filter') || '').toLowerCase() === active;
          button.classList.toggle('on', isActive);
          button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });

        scope.querySelectorAll('[data-filter-card]').forEach(function (card) {
          var values = tokens(card.getAttribute('data-filter-values'));
          var search = (card.getAttribute('data-filter-search') || '').toLowerCase();
          var matchesFilter = active === 'all' || values.indexOf(active) !== -1;
          var matchesSearch = !query || search.indexOf(query) !== -1;
          var show = matchesFilter && matchesSearch;
          card.hidden = !show;
          if (show) visibleCount += 1;
        });

        scope.querySelectorAll('[data-filter-group]').forEach(function (group) {
          group.hidden = group.querySelectorAll('[data-filter-card]:not([hidden])').length === 0;
        });

        var empty = scope.querySelector('[data-filter-empty]');
        if (empty) empty.hidden = visibleCount !== 0;
      }

      function init(root) {
        (root || document).querySelectorAll('[data-filter-scope]').forEach(update);
      }

      window.BitcoinMindFilterClick = function (button) {
        var scope = button && button.closest('[data-filter-scope]');
        if (!scope) return;
        scope.setAttribute('data-active-filter', button.getAttribute('data-filter') || 'all');
        update(scope);
      };

      window.BitcoinMindFilterInput = function (input) {
        var scope = input && input.closest('[data-filter-scope]');
        if (scope) update(scope);
      };

      document.addEventListener('click', function (event) {
        var button = event.target.closest && event.target.closest('[data-filter-button]');
        if (!button) return;
        window.BitcoinMindFilterClick(button);
      });

      document.addEventListener('input', function (event) {
        if (!event.target.matches || !event.target.matches('[data-filter-search]')) return;
        window.BitcoinMindFilterInput(event.target);
      });

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function () { init(document); });
      } else {
        init(document);
      }
    })();
  </script>
</body>
</html>

<style is:global>
  .grain {
    position: fixed;
    inset: 0;
    background-image: url('/grain.png');
    background-size: 256px;
    z-index: 9998;
    pointer-events: none;
    opacity: 0.028;
    mix-blend-mode: overlay;
  }
</style>
